// ===========================================================================
// Verified Knowledge domain (kg.v1)  —  feature/verified-knowledge-service
// ===========================================================================
// A DISTINCT verified fact graph produced/consumed by PetsInMyCity (and future
// EMG properties). This is NOT an embedding / RAG document store: it stores
// verified entities, claims, relationships, sources, provenance and lifecycle
// history with full versioning. Loop persists and returns these objects; the
// producer's Knowledge Delivery Platform (KDP) remains the delivery authority.
//
// Tenancy follows the loop_events precedent: additive tables with plain scalar
// scope columns (platform / property / organizationId) and NO foreign keys to
// existing production tables, so the migration stays purely additive and does
// not require a provisioned Organization row. Scope isolation is enforced at the
// query level by the repository. Stable producer ids are unique WITHIN a scope,
// so the composite uniqueness keys always include (platform, property, ...).

model VerifiedKnowledgeSource {
  id             String    @id @default(cuid())
  // scope
  platform       String
  property       String
  organizationId String?
  // stable producer-supplied id (unique within scope)
  sourceKey      String
  tier           Int?
  kind           String?
  title          String?
  publisher      String?
  url            String?
  accessed       DateTime?
  publishedAt    DateTime?
  quote          String?
  capturedBy     String?
  authorityScope String?
  limitations    String?
  reviewCadence  String?
  attributes     Json      @default("{}")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  provenance VerifiedKnowledgeProvenance[]

  @@unique([platform, property, sourceKey])
  @@index([platform, property, organizationId])
  @@map("vk_sources")
}

model VerifiedKnowledgeEntity {
  id             String   @id @default(cuid())
  platform       String
  property       String
  organizationId String?
  entityKey      String // stable producer-supplied id
  type           String
  name           String?
  aliases        String[] @default([])
  status         String?
  confidence     String?
  verification   String?
  safetyCritical Boolean  @default(false)
  attributes     Json     @default("{}")
  currentVersion Int      @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  versions VerifiedKnowledgeEntityVersion[]

  @@unique([platform, property, entityKey])
  @@index([platform, property, organizationId])
  @@index([platform, property, type])
  @@map("vk_entities")
}

model VerifiedKnowledgeEntityVersion {
