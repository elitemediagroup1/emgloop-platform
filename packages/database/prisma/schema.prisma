// EMG Loop — Platform Database Schema
// AI-first, industry-agnostic, multi-tenant SaaS.
//
// Design rules:
//  - Every tenant-scoped row carries organizationId (multi-tenancy boundary).
//  - Industry-specific shape lives in JSON \`metadata\` / \`attributes\` columns,
//    NOT in industry-specific tables. The core stays generic.
//  - Providers are abstracted: we store ProviderConnection + provider/externalId
//    references rather than hard-coding Twilio/Stripe/etc.
//  - Soft, append-only intelligence (Signal) is first-class, not bolted on.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum IndustryType {
  HOME_SERVICES
  NAIL_SALON
  BARBERSHOP
  MEDICAL
  DENTAL
  RESTAURANT
  PIZZERIA
  LAW_FIRM
  AUTOMOTIVE
  BEAUTY_SPA
  FITNESS
  GENERIC
}

enum OrganizationStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELED
}

enum UserStatus {
  INVITED
  ACTIVE
  DISABLED
}

enum ChannelType {
  PHONE
  SMS
  EMAIL
  WEB_CHAT
  WHATSAPP
  IN_PERSON
  SOCIAL
  OTHER
}

enum InteractionDirection {
  INBOUND
  OUTBOUND
  INTERNAL
}

enum ConversationStatus {
  OPEN
  PENDING
  SNOOZED
  CLOSED
}

enum ActorType {
  CUSTOMER
  HUMAN_AGENT
  AI_AGENT
  SYSTEM
}

enum MessageType {
  TEXT
  AUDIO
  IMAGE
  FILE
  TRANSCRIPT
  EVENT
  SYSTEM
}

enum BookingStatus {
  REQUESTED
  CONFIRMED
  RESCHEDULED
  COMPLETED
  NO_SHOW
  CANCELED
}

enum OrderStatus {
  DRAFT
  PLACED
  IN_PROGRESS
  READY
  FULFILLED
  CANCELED
  REFUNDED
}

enum FulfillmentType {
  PICKUP
  DELIVERY
  DINE_IN
  ON_SITE
  REMOTE
}

enum ServiceRequestStatus {
  NEW
  QUALIFYING
  QUOTED
  WON
  LOST
  ON_HOLD
}

enum SignalType {
  INTENT
  SENTIMENT
  CHURN_RISK
  UPSELL_OPPORTUNITY
  LIFETIME_VALUE
  NO_SHOW_RISK
  SATISFACTION
  LANGUAGE
  TOPIC
  CUSTOM
}

enum WorkflowTrigger {
  EVENT
  SCHEDULE
  MANUAL
  WEBHOOK
  SIGNAL
}

enum WorkflowRunStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  CANCELED
}

enum AIAgentType {
  PHONE
  SMS
  CHAT
  ORDER_TAKING
  RECEPTIONIST
  FOLLOW_UP
  CUSTOM
}

enum ProviderCategory {
  AI
  VOICE
  SMS
  EMAIL
  PAYMENT
  CALENDAR
  INGESTION
  ANALYTICS
}

enum ConnectionStatus {
  PENDING
  CONNECTED
  ERROR
  DISCONNECTED
}

enum IntegrationEventStatus {
  RECEIVED
  PROCESSING
  PROCESSED
  FAILED
  IGNORED
}

// ---------------------------------------------------------------------------
// Tenancy & Identity
// ---------------------------------------------------------------------------

model Organization {
  id        String             @id @default(cuid())
  name      String
  slug      String             @unique
  industry  IndustryType       @default(GENERIC)
  status    OrganizationStatus @default(TRIAL)
  timezone  String             @default("UTC")
  // Source attribution. ServicesInMyCity is the FIRST data source, not the product.
  sourceKey String? // e.g. "servicesinmycity"
  settings  Json               @default("{}")
  metadata  Json               @default("{}")
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  locations               Location[]
  users                   User[]
  roles                   Role[]
  customers               Customer[]
  interactions            Interaction[]
  conversations           Conversation[]
  messages                Message[]
  bookings                Booking[]
  orders                  Order[]
  serviceRequests         ServiceRequest[]
  signals                 Signal[]
  workflows               Workflow[]
  workflowRuns            WorkflowRun[]
  aiAgents                AIAgent[]
  aiEmployees             AIEmployee[]
  voiceProfiles           VoiceProfile[]
  providerConnections     ProviderConnection[]
  integrationEvents       IntegrationEvent[]
  auditLogs               AuditLog[]
  domainEvents            DomainEvent[]
  // --- Sprint 2: identity & OS core ---
  organizationSettings    OrganizationSettings?
  organizationPreferences OrganizationPreferences?
  organizationDNA         OrganizationDNA?
  invitations             Invitation[]
  passwordResets          PasswordReset[]
  sessions                UserSession[]
  customPermissions       Permission[]
  capabilities            OrganizationCapability[]

  @@index([sourceKey])
  @@map("organizations")
}

model Location {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  slug           String?
  timezone       String   @default("UTC")
  phone          String?
  email          String?
  addressLine1   String?
  addressLine2   String?
  city           String?
  region         String?
  postalCode     String?
  country        String?
  latitude       Float?
  longitude      Float?
  hours          Json     @default("{}") // weekly hours / exceptions
  metadata       Json     @default("{}")
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bookings        Booking[]
  orders          Order[]
  serviceRequests ServiceRequest[]
  aiAgents        AIAgent[]
  aiEmployees     AIEmployee[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@map("locations")
}

model Role {
  id             String   @id @default(cuid())
  organizationId String
  name           String // e.g. "owner", "manager", "agent"
  description    String?
  isSystem       Boolean  @default(false)
  permissions    Json     @default("[]") // array of permission keys
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  users        User[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("roles")
}

model User {
  id             String     @id @default(cuid())
  organizationId String
  roleId         String?
  email          String
  name           String?
  phone          String?
  status         UserStatus @default(INVITED)
  // Auth is provider-agnostic: store external auth subject, never raw passwords.
  authProvider   String? // e.g. "clerk", "auth0", "supabase"
  externalAuthId String?
  lastLoginAt    DateTime?
  metadata       Json       @default("{}")
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role         Role?        @relation(fields: [roleId], references: [id], onDelete: SetNull)

  assignedConversations Conversation[]  @relation("ConversationAssignee")
  auditLogs             AuditLog[]
  // --- Sprint 2 ---
  sentInvitations       Invitation[]    @relation("InvitationInviter")
  passwordResets        PasswordReset[]
  userSessions          UserSession[]

  @@unique([organizationId, email])
  @@index([organizationId])
  @@index([externalAuthId])
  @@map("users")
}

// ---------------------------------------------------------------------------
// Customer & Intelligence
// ---------------------------------------------------------------------------

model Customer {
  id             String   @id @default(cuid())
  organizationId String
  externalId     String? // id in the source system (e.g. ServicesInMyCity)
  firstName      String?
  lastName       String?
  email          String?
  phone          String?
  locale         String?
  tags           String[] @default([])
  // Industry-specific fields live here, keeping the core generic.
  attributes     Json     @default("{}")
  metadata       Json     @default("{}")
  firstSeenAt    DateTime @default(now())
  lastSeenAt     DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  interactions    Interaction[]
  conversations   Conversation[]
  bookings        Booking[]
  orders          Order[]
  serviceRequests ServiceRequest[]
  signals         Signal[]

  @@unique([organizationId, externalId])
  @@index([organizationId])
  @@index([organizationId, email])
  @@index([organizationId, phone])
  @@map("customers")
}

// A single touchpoint on the customer timeline (channel-agnostic).
model Interaction {
  id             String               @id @default(cuid())
  organizationId String
  customerId     String?
  conversationId String?
  channel        ChannelType
  kind           InteractionKind      @default(OTHER)
  direction      InteractionDirection
  occurredAt     DateTime             @default(now())
  summary        String?
  // Provider attribution without provider lock-in.
  provider       String? // e.g. "telnyx", "twilio"
  externalId     String?
  payload        Json                 @default("{}")
  metadata       Json                 @default("{}")
  createdAt      DateTime             @default(now())

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([organizationId, occurredAt])
  @@index([organizationId, kind])
  @@index([customerId])
  @@index([conversationId])
  @@map("interactions")
}

// A threaded conversation spanning one or more messages on a channel.
model Conversation {
  id             String             @id @default(cuid())
  organizationId String
  customerId     String?
  assigneeId     String?
  aiAgentId      String?
  channel        ChannelType
  status         ConversationStatus @default(OPEN)
  subject        String?
  lastMessageAt  DateTime?
  metadata       Json               @default("{}")
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  assignee     User?         @relation("ConversationAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  aiAgent      AIAgent?      @relation(fields: [aiAgentId], references: [id], onDelete: SetNull)
  messages     Message[]
  interactions Interaction[]
  signals      Signal[]

  @@index([organizationId, status])
  @@index([customerId])
  @@map("conversations")
}

model Message {
  id             String      @id @default(cuid())
  organizationId String
  conversationId String
  actorType      ActorType
  actorId        String? // userId, customerId, or aiAgentId depending on actorType
  type           MessageType @default(TEXT)
  body           String?
  // Provider attribution (e.g. message SID) without coupling to a provider.
  provider       String?
  externalId     String?
  attachments    Json        @default("[]")
  metadata       Json        @default("{}")
  sentAt         DateTime    @default(now())
  createdAt      DateTime    @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, sentAt])
  @@index([organizationId])
  @@map("messages")
}

// ---------------------------------------------------------------------------
// Commerce: Booking / Order / ServiceRequest
// ---------------------------------------------------------------------------

model Booking {
  id               String        @id @default(cuid())
  organizationId   String
  locationId       String?
  customerId       String?
  status           BookingStatus @default(REQUESTED)
  title            String?
  startAt          DateTime
  endAt            DateTime?
  partySize        Int? // covers restaurant tables, group appointments
  // Calendar provider abstraction.
  calendarProvider String?
  calendarEventId  String?
  // Industry shape (service type, stylist, room, table, etc.) lives here.
  items            Json          @default("[]")
  attributes       Json          @default("{}")
  metadata         Json          @default("{}")
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  location     Location?    @relation(fields: [locationId], references: [id], onDelete: SetNull)
  customer     Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([organizationId, startAt])
  @@index([customerId])
  @@map("bookings")
}

model Order {
  id                String          @id @default(cuid())
  organizationId    String
  locationId        String?
  customerId        String?
  status            OrderStatus     @default(DRAFT)
  fulfillment       FulfillmentType @default(PICKUP)
  number            String? // human-facing order number
  currency          String          @default("USD")
  subtotalCents     Int             @default(0)
  taxCents          Int             @default(0)
  tipCents          Int             @default(0)
  totalCents        Int             @default(0)
  // Line items kept as JSON so any vertical (pizza, retail, services) fits.
  items             Json            @default("[]")
  // Payment provider abstraction — no Stripe coupling in the core.
  paymentProvider   String?
  paymentExternalId String?
  scheduledFor      DateTime?
  attributes        Json            @default("{}")
  metadata          Json            @default("{}")
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  location     Location?    @relation(fields: [locationId], references: [id], onDelete: SetNull)
  customer     Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@unique([organizationId, number])
  @@index([organizationId, status])
  @@index([customerId])
  @@map("orders")
}

// A lead / quote-style request (home services, law firms, etc.).
model ServiceRequest {
  id                  String               @id @default(cuid())
  organizationId      String
  locationId          String?
  customerId          String?
  status              ServiceRequestStatus @default(NEW)
  source              String? // e.g. "servicesinmycity", "web", "phone"
  category            String? // industry-defined service category
  summary             String?
  details             Json                 @default("{}")
  estimatedValueCents Int?
  attributes          Json                 @default("{}")
  metadata            Json                 @default("{}")
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  location     Location?    @relation(fields: [locationId], references: [id], onDelete: SetNull)
  customer     Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([organizationId, status])
  @@index([customerId])
  @@map("service_requests")
}

// Append-only behavioral / AI intelligence attached to a customer or conversation.
model Signal {
  id             String     @id @default(cuid())
  organizationId String
  customerId     String?
  conversationId String?
  type           SignalType
  key            String // machine key, e.g. "churn_risk"
  label          String? // human label
  valueNumber    Float?
  valueString    String?
  confidence     Float? // 0..1
  source         String? // model / agent that produced it
  observedAt     DateTime   @default(now())
  metadata       Json       @default("{}")
  createdAt      DateTime   @default(now())

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([organizationId, type])
  @@index([customerId, type])
  @@map("signals")
}

// ---------------------------------------------------------------------------
// Automation: Workflow / WorkflowRun
// ---------------------------------------------------------------------------

model Workflow {
  id             String          @id @default(cuid())
  organizationId String
  name           String
  description    String?
  trigger        WorkflowTrigger @default(EVENT)
  // Trigger config + step graph stored declaratively (provider-agnostic).
  triggerConfig  Json            @default("{}")
  definition     Json            @default("{}")
  isActive       Boolean         @default(false)
  version        Int             @default(1)
  metadata       Json            @default("{}")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  runs         WorkflowRun[]

  @@index([organizationId, isActive])
  @@map("workflows")
}

model WorkflowRun {
  id             String            @id @default(cuid())
  organizationId String
  workflowId     String
  status         WorkflowRunStatus @default(PENDING)
  triggeredBy    String? // event id / user id / schedule
  input          Json              @default("{}")
  output         Json              @default("{}")
  error          String?
  startedAt      DateTime?
  finishedAt     DateTime?
  createdAt      DateTime          @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workflow     Workflow     @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
  @@index([workflowId])
  @@map("workflow_runs")
}

// ---------------------------------------------------------------------------
// AI Agents & Voice
// ---------------------------------------------------------------------------

model AIAgent {
  id             String      @id @default(cuid())
  organizationId String
  locationId     String?
  voiceProfileId String?
  name           String
  type           AIAgentType @default(CHAT)
  // The model provider is abstracted (Claude today, others tomorrow).
  modelProvider  String? // e.g. "anthropic"
  model          String? // e.g. "claude-..."
  systemPrompt   String?
  config         Json        @default("{}")
  isActive       Boolean     @default(false)
  metadata       Json        @default("{}")
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  location      Location?      @relation(fields: [locationId], references: [id], onDelete: SetNull)
  voiceProfile  VoiceProfile?  @relation(fields: [voiceProfileId], references: [id], onDelete: SetNull)
  aiEmployees   AIEmployee[]
  conversations Conversation[]

  @@index([organizationId, type])
  @@map("ai_agents")
}

// AIEmployee — a first-class, organization-level AI actor (Sprint 2.5).
//
// Relationship to AIAgent:
//   AIEmployee is the HIGH-LEVEL identity ("who": a named role such as
//   "HVAC Dispatcher" or "Pizza Order Taker"). It owns DNA inheritance,
//   channels, knowledge access, escalation and operating hours, and can be a
//   first-class permission subject.
//   AIAgent is the LOWER-LEVEL EXECUTION RUNTIME ("how": the model/provider,
//   system prompt and runtime config a single agent run uses). One AIEmployee
//   may be backed by one or more AIAgent runtime configs over time.
// AIAgent is therefore reserved for execution; new orchestration targets
// AIEmployee. See docs/AI_EMPLOYEE_SYSTEM.md for the full decision record.
model AIEmployee {
  id              String           @id @default(cuid())
  organizationId  String
  locationId      String?
  voiceProfileId  String?
  agentId         String?
  name            String
  title           String?
  status          AIEmployeeStatus @default(DRAFT)
  channels        ChannelType[]
  inheritsDNA     Boolean          @default(true)
  dnaOverrides    Json             @default("{}")
  knowledgeAccess Json             @default("{}")
  escalationRules Json             @default("{}")
  operatingHours  Json             @default("{}")
  providerPrefs   Json             @default("{}")
  attributes      Json             @default("{}")
  metadata        Json             @default("{}")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  location     Location?     @relation(fields: [locationId], references: [id], onDelete: SetNull)
  voiceProfile VoiceProfile? @relation(fields: [voiceProfileId], references: [id], onDelete: SetNull)
  agent        AIAgent?      @relation(fields: [agentId], references: [id], onDelete: SetNull)
  permissions  Permission[]

  @@index([organizationId, status])
  @@index([organizationId, locationId])
  @@map("ai_employees")
}

model VoiceProfile {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  // Voice provider abstraction (ElevenLabs today, others later).
  voiceProvider  String? // e.g. "elevenlabs"
  voiceId        String? // provider-specific voice id
  language       String   @default("en")
  gender         String?
  config         Json     @default("{}") // stability, similarity, speed, etc.
  metadata       Json     @default("{}")
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  aiAgents     AIAgent[]
  aiEmployees  AIEmployee[]

  @@index([organizationId])
  @@map("voice_profiles")
}

// ---------------------------------------------------------------------------
// Provider Abstraction & Integration Plumbing
// ---------------------------------------------------------------------------

// A tenant's connection to an external provider (one row per connected provider).
model ProviderConnection {
  id                String           @id @default(cuid())
  organizationId    String
  category          ProviderCategory
  provider          String // e.g. "anthropic", "twilio", "telnyx", "stripe"
  displayName       String?
  status            ConnectionStatus @default(PENDING)
  externalAccountId String?
  // Secrets are NOT stored raw here in production — store a reference to a
  // secrets manager. Kept generic and provider-agnostic.
  credentialsRef    String?
  config            Json             @default("{}")
  scopes            String[]         @default([])
  connectedAt       DateTime?
  lastSyncedAt      DateTime?
  metadata          Json             @default("{}")
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  integrationEvents IntegrationEvent[]

  @@unique([organizationId, category, provider])
  @@index([organizationId, category])
  @@map("provider_connections")
}

// Inbound/outbound events from providers (webhooks, syncs) — generic envelope.
model IntegrationEvent {
  id                   String                 @id @default(cuid())
  organizationId       String
  providerConnectionId String?
  category             ProviderCategory?
  provider             String?
  eventType            String // provider-defined event name
  externalId           String? // provider event/delivery id (idempotency)
  status               IntegrationEventStatus @default(RECEIVED)
  payload              Json                   @default("{}")
  error                String?
  receivedAt           DateTime               @default(now())
  processedAt          DateTime?
  createdAt            DateTime               @default(now())

  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  providerConnection ProviderConnection? @relation(fields: [providerConnectionId], references: [id], onDelete: SetNull)

  @@unique([provider, externalId])
  @@index([organizationId, status])
  @@index([providerConnectionId])
  @@map("integration_events")
}

// ---------------------------------------------------------------------------
// Audit
// ---------------------------------------------------------------------------

model AuditLog {
  id             String    @id @default(cuid())
  organizationId String
  userId         String?
  actorType      ActorType @default(SYSTEM)
  action         String // e.g. "customer.updated", "booking.canceled"
  entityType     String?
  entityId       String?
  before         Json?
  after          Json?
  ip             String?
  userAgent      String?
  metadata       Json      @default("{}")
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

// ===========================================================================
// SPRINT 2 — Identity & Operating-System Core
//
// The platform must understand Organizations, Locations, Users, Roles,
// Permissions, Capabilities, AI Employees, and Provider Connections BEFORE it
// understands customers. Additive to the Sprint 1 core; nothing removed/forked.
// Architecture foundation only: no production auth flows, no live integrations.
// ===========================================================================

enum SystemRole {
  OWNER
  ADMIN
  MANAGER
  EMPLOYEE
  AI_EMPLOYEE
  READ_ONLY
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum AuthProviderType {
  PASSWORD
  GOOGLE_OAUTH
  MICROSOFT_OAUTH
  SAML_SSO
  OIDC_SSO
  MAGIC_LINK
}

enum CapabilityStatus {
  AVAILABLE
  ENABLED
  CONFIGURED
  PAUSED
  DISABLED
}

enum PermissionEffect {
  ALLOW
  DENY
}

model OrganizationSettings {
  id             String   @id @default(cuid())
  organizationId String   @unique
  // DEPRECATED (Sprint 2.5): capability enablement is governed solely by
  // OrganizationCapability rows. Retained only for backward-compat migration;
  // MUST NOT be treated as the source of truth. Do not add new reads/writes here.
  modules        Json     @default("{}")
  limits         Json     @default("{}")
  featureFlags   Json     @default("{}")
  defaults       Json     @default("{}")
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("organization_settings")
}

model OrganizationPreferences {
  id             String   @id @default(cuid())
  organizationId String   @unique
  locale         String   @default("en-US")
  dateFormat     String   @default("MM/DD/YYYY")
  timeFormat     String   @default("12h")
  weekStart      Int      @default(0)
  currency       String   @default("USD")
  notifications  Json     @default("{}")
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

