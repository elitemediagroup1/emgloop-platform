// ---------------------------------------------------------------------------
// MarketplaceCall — the canonical, sensor-neutral operational projection of a
// call. This is NOT a CallGrid table: `provider` records which sensor produced
// the row (CallGrid today; Ringba/Invoca/an internal auction tomorrow project
// into the SAME shape). The raw Interaction + Interaction.metadata remain the
// audit record and are never stopped or deleted; this row is the normalized,
// queryable projection the Intelligence layer reads instead of parsing JSON.
//
// Invariants (see docs/CALLGRID_INTELLIGENCE_FOUNDATION.md §Persistence):
//   • Idempotent: unique on (provider, externalId) — re-projecting is an upsert.
//   • Traceable: interactionId + provider + externalId point back to the source.
//   • Money is integer CENTS. Unknown values are null, NEVER defaulted to 0.
//   • Attribution is nullable EXTERNAL-reference ids only — no Buyer/Vendor/
//     Source/Campaign tables are introduced here; canonical entities come later
//     and can be linked without rewriting rows.
//   • sourceOccurredAt (when the call happened) is separate from createdAt/
//     updatedAt (when Loop wrote/updated the projection).
// ---------------------------------------------------------------------------
model MarketplaceCall {
  id             String @id @default(cuid())
  organizationId String

  // Provenance: `provider` is the sensor id (e.g. 'callgrid'). Sensor-neutral.
  provider      String
  externalId    String
  // Traceability back to the raw source event (Interaction.id). Kept as a plain
  // reference (not a formal relation) so the raw Interaction model is untouched.
  interactionId String?

  // When the call actually occurred at the source.
  sourceOccurredAt DateTime

  // Status / disposition. `status` is the canonical event type; `rawStatus` is
  // the provider-native string (preserves BUSY/FAILED/REJECTED distinctions the
  // coarse taxonomy collapses).
  status                   String?
  rawStatus                String?
  endedBy                  String?
  // CONNECTED duration: elapsed time AFTER the call connects, per CallGrid's
  // CallDuration. Renamed from `durationSeconds` (Sprint 37) because that name
  // read as total elapsed time and invited comparison against total-duration
  // figures that measure something else. Billable duration is a THIRD quantity
  // and must never populate this field.
  //
  // @map keeps the physical column so no migration is required.
  connectedDurationSeconds Int?    @map("durationSeconds")

  // Attribution — nullable external-reference ids + best-known labels.
  buyerExternalId       String?
  buyerLabel            String?
  vendorExternalId      String?
  vendorLabel           String?
  sourceExternalId      String?
  sourceLabel           String?
  campaignExternalId    String?
  campaignLabel         String?
  destinationExternalId String?

  // Geo (nullable — only the webhook path supplies these today).
  callerState String?
  callerZip   String?

  // Economics — integer CENTS, null when unmeasured (never 0-defaulted).
  revenueCents Int?
  payoutCents  Int?
  costCents    Int?
  rateCents    Int?

  // Outcome flags — null when the sensor did not say.
  // RENAMED from `qualified` (Sprint 36). CallGrid sends no qualified field of
  // any kind — this is DERIVED by Loop as billable OR converted OR paid, and
  // sat here beside genuine provider flags where it was indistinguishable from
  // one. It means "the call produced a positive commercial outcome", NOT "the
  // call met a qualification standard", and an executive reading a
  // qualification RATE reads it as call quality.
  //
  // @map keeps the physical column `qualified` so this rename needs NO
  // migration: migrations here are manually dispatched, and a code/schema skew
  // would take production down. Rename the column itself in a dedicated
  // migration when one is being deployed anyway.
  monetized Boolean? @map("qualified")
  billable  Boolean?
  converted Boolean?
  paid      Boolean?
  completed Boolean?
  noRoute   Boolean?
  duplicate Boolean?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, externalId])
  @@index([organizationId, sourceOccurredAt])
  @@index([organizationId, buyerExternalId])
  @@index([organizationId, vendorExternalId])
  @@index([organizationId, sourceExternalId])
  @@index([organizationId, campaignExternalId])
  @@index([organizationId, status])
  @@index([organizationId, monetized])
  @@index([organizationId, billable])
  @@index([organizationId, converted])
  @@map("marketplace_calls")
}

// ---------------------------------------------------------------------------
// Auction reporting — verified aggregate snapshots
// ---------------------------------------------------------------------------
//
// These three models store CallGrid's AGGREGATE report output. They are not
// event tables. CallGrid exposes no event-level bid or ping record, so a
// `MarketplaceBid` row would be a fabrication with a plausible schema — the
// most expensive kind.
//
// TWO GRAINS, DELIBERATELY UNJOINED
//   MarketplaceBidSourceSnapshot       one row per SOURCE per report window
//   MarketplacePingDestinationSnapshot one row per DESTINATION per report window
//
// Source and destination are opposite sides of the marketplace. There is no
// foreign key between them and no shared identifier, because the provider
// asserts no relationship between them. Nothing may join them by name.
//
// UNITS
//   *Cents    integer cents. Converted once, at the ingestion boundary, by the
//             same `Math.round(dollars * 100)` rule MarketplaceCall uses. The
//             dollars premise is EVIDENCE-GATED per run — see
//             MarketplaceReportRun.moneyUnitEvidence. It is not assumed here.
//   *Percent  percentage POINTS as the provider reported them: 14.473684 means
//             14.473684%. Provider rates are stored verbatim and never
//             recomputed over them; Loop-derived rates are computed at read
//             time from counts, where the denominator is explicit.
//
// NULL vs ZERO
//   Every metric is nullable. Null means the provider did not report the field.
//   Zero means the provider reported zero. Ingestion never coerces one into the
//   other.

/// Aggregate bid statistics for one source over one report window.
/// Combines GET /api/reports/bidStats with GET /api/reports/bidStats/rejections,
/// which share the source grain and are joined on sourceId within one window.
model MarketplaceBidSourceSnapshot {
  id             String @id @default(cuid())
  organizationId String

  /// Sensor id, e.g. 'callgrid'. Sensor-neutral by design.
  provider String

  /// Inclusive window as REQUESTED, in UTC. See reportTimezone.
  reportWindowStart DateTime
  reportWindowEnd   DateTime

  /// The timezone Loop requested the window in. NOT a claim about the timezone
  /// CallGrid buckets in: the three GET report endpoints accept no
  /// reportTimeZone parameter, so provider-side bucketing is UNVERIFIED.
  reportTimezone String

  /// Provider-native source id. The only legitimate join key.
  sourceExternalId String
  sourceName       String?

  // Provenance
  sourceEndpoint      String
  sourcePage          Int?
  sourceTotalPages    Int?
  providerPayloadHash String
  fetchedAt           DateTime

  // Observed bidStats metrics — null means not reported.
  total    Int?
  bids     Int?
  rated    Int?
  won      Int?
  rejected Int?

  totalBidAmountCents Int?
  totalWonAmountCents Int?
  avgBidCents         Int?
  avgWinningBidCents  Int?

  /// Provider-reported rates, in percentage points, stored verbatim.
  winRatePercent    Float?
  bidRatePercent    Float?
  rejectRatePercent Float?

  // Observed bidStats/rejections metrics. Null means the rejections report
  // returned no row for this source — which is NOT the same as zero rejections.
  rejectedDetail   Int?
  callerIdRejected Int?
  closed           Int?
  paused           Int?
  /// Provider `duplicate`. Distinct from duplicateBids; never summed together.
  duplicateCaller  Int?
  duplicateBids    Int?
  failedAcceptance Int?
  failedTagRules   Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, provider, reportWindowStart, reportWindowEnd, sourceExternalId], name: "bid_source_snapshot_identity")
  @@index([organizationId, reportWindowStart])
  @@index([organizationId, provider, sourceExternalId])
  @@map("marketplace_bid_source_snapshots")
}

/// Aggregate ping statistics for one destination over one report window.
/// Source: GET /api/reports/pingStats.
model MarketplacePingDestinationSnapshot {
  id             String @id @default(cuid())
  organizationId String

  provider String

  reportWindowStart DateTime
  reportWindowEnd   DateTime
  reportTimezone    String

  destinationExternalId String
  destinationName       String?

  /// The provider's own row date. pingStats buckets rows per day, so a
  /// multi-day window returns one row per destination PER DAY. Ingestion is
  /// single-day; this field is what lets it prove that rather than assume it.
  providerRowDate DateTime?

  // Provenance
  sourceEndpoint      String
  sourcePage          Int?
  sourceTotalPages    Int?
  providerPayloadHash String
  fetchedAt           DateTime

  // Observed metrics — null means not reported.
  accepted         Int?
  agents           Int?
  failedAcceptance Int?
  failedTagRules   Int?
  minRevenue       Int?
  missingAmount    Int?
  invalidNumber    Int?
  durationElapsed  Int?
  pingTimeout      Int?
  apiFailed        Int?
  rateLimited      Int?
  suppressed       Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, provider, reportWindowStart, reportWindowEnd, destinationExternalId], name: "ping_destination_snapshot_identity")
  @@index([organizationId, reportWindowStart])
  @@index([organizationId, provider, destinationExternalId])
  @@map("marketplace_ping_destination_snapshots")
}

/// One ingestion attempt against one report endpoint for one window.
///
/// This exists so that "no rows" can be told apart from "we could not read the
/// report". Without it, a 500 and an empty day are the same absence of data,
/// and the platform would render a provider outage as zero marketplace activity.
model MarketplaceReportRun {
  id             String @id @default(cuid())
  organizationId String

  provider       String
  /// 'bidStats' | 'bidRejections' | 'pingStats'. Not an enum: the set is defined
  /// by what the provider verifiably exposes, and widening it must be a code
  /// change with evidence, not a migration.
  endpoint       String
  /// The HTTP path actually called.
  sourceEndpoint String

  reportWindowStart DateTime
  reportWindowEnd   DateTime
  reportTimezone    String

  status MarketplaceReportRunStatus

  /// Set only for non-success statuses. Never contains the credential.
  errorClassification String?
  errorDetail         String?

  fetchedAt        DateTime
  pagesFetched     Int?
  sourceTotalPages Int?
  rowCount         Int?
  /// True when pagination hit its cap. A truncated report is never reconciled
  /// or aggregated as if it were complete.
  truncated        Boolean  @default(false)

  inserted Int @default(0)
  updated  Int @default(0)
  skipped  Int @default(0)
  failed   Int @default(0)

  /// Provider footerTotals, verbatim. Kept SEPARATE from recomputedTotals so a
  /// provider/Loop disagreement stays visible instead of being averaged away.
  providerFooterTotals Json?
  /// Totals Loop recomputed by summing the rows it stored.
  recomputedTotals     Json?

  /// Whether the dollars premise behind every *Cents column was PROVEN for this
  /// run (a money field carried fractional decimals) or merely consistent with
  /// the data (all integers). Money-based findings are gated on 'proven-dollars'.
  moneyUnitEvidence String?

  /// Row keys actually returned, for drift detection against the observed contract.
  observedRowKeys Json?

  providerPayloadHash String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, provider, endpoint, reportWindowStart, reportWindowEnd], name: "report_run_identity")
  @@index([organizationId, provider, endpoint, fetchedAt])
  @@map("marketplace_report_runs")
}

enum MarketplaceReportRunStatus {
  /// Every declared page read, rows stored.
  SUCCESS
  /// Read cleanly, provider returned no rows. A real, reportable fact.
  EMPTY
  /// Non-2xx or network failure.
  ENDPOINT_FAILURE
  /// 2xx whose body was not JSON.
  MALFORMED_RESPONSE
  /// 2xx JSON whose shape we could not read. NEVER treated as empty.
  UNKNOWN_ENVELOPE
  /// Some pages read, page budget exhausted before totalPages.
  PARTIAL_PAGINATION
}
