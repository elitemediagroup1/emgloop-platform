  type           String // next_action_ready | assigned | completed | approval_needed
  title          String
  body           String
  readAt         DateTime?
  createdAt      DateTime  @default(now())
  metadata       Json      @default("{}")

  workInstance WorkInstance @relation(fields: [workInstanceId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@map("work_notifications")
}

model WorkComment {
