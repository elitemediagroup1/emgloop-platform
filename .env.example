# ---------------------------------------------------------------------------
# EMG Loop — Environment Example
# Copy to .env / .env.local and fill in. NEVER commit real secrets.
# Sprint 1: NO real provider integrations. These are placeholders only.
# ---------------------------------------------------------------------------

# Core
NODE_ENV=development
APP_URL=https://app.emgloop.com

# Database (PostgreSQL)
DATABASE_URL=postgresql://emgloop:emgloop@localhost:5432/emgloop?schema=public

# --- Provider placeholders (NOT integrated yet) ---
# AI provider (e.g. Anthropic / Claude)
AI_PROVIDER=
AI_API_KEY=

# Voice provider (e.g. ElevenLabs)
VOICE_PROVIDER=
VOICE_API_KEY=

# SMS / telephony provider (e.g. Twilio, Telnyx)
SMS_PROVIDER=
SMS_API_KEY=

# Email provider (e.g. SendGrid, Mailgun)
EMAIL_PROVIDER=
EMAIL_API_KEY=

# Payment provider (e.g. Stripe)
PAYMENT_PROVIDER=
PAYMENT_API_KEY=

# Calendar provider (e.g. Google Calendar)
CALENDAR_PROVIDER=
CALENDAR_CLIENT_ID=
CALENDAR_CLIENT_SECRET=

# Direct (non-pooled) database connection. Used for prisma migrate deploy.
DIRECT_DATABASE_URL=postgresql://emgloop:emgloop@localhost:5432/emgloop?schema=public

# --- TEMPORARY (hotfix-neon-db-setup) ---
# Secret token that guards POST /api/admin/setup-database. The endpoint is
# disabled unless this is set. Set a long random value in Netlify ONLY; do not
# commit a real value. Remove this and the endpoint in the cleanup hotfix.
SETUP_SECRET=
